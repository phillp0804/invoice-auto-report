# AI API
# AI_PROVIDER 決定 ocr_service/classifier_service 實際呼叫哪個廠商："claude" 或 "gemini"
# 兩邊金鑰都可以先填著，切換只需要改 AI_PROVIDER，不用改程式碼
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# 資料庫
DATABASE_URL=sqlite:///./invoices.db

# 發票圖片備份儲存目錄（相對於 backend/ 執行目錄）
UPLOAD_DIR=uploads

# 公司統編（用於比對發票買方統編是否為本公司）
COMPANY_TAX_ID=

# n8n webhook
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
